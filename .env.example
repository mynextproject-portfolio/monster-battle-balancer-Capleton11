# D&D 5e API Configuration
# Copy this file to .env and update values if needed
DND_API_BASE_URL=https://www.dnd5eapi.co/api/2014
DND_API_IMAGE_BASE_URL=https://www.dnd5eapi.co

# UI language: "ja" (default, used by playtester builds) or "en" (dev team).
# Leave unset for Japanese. Developers who want the English UI set:
UI_LANG=en
